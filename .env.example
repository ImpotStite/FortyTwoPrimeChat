# --- Site URL (Open Graph / Twitter / canonical in index.html; sitemap + robots.txt at build; RouteSeo) ---
# Production builds default to the Vercel URL if unset. Set for a custom domain (no trailing slash).
# VITE_SITE_URL=https://your-domain.example

# --- Fortytwo Prime (default at /) ---
# Privy app id (public). External wallets only.
VITE_PRIVY_APP_ID=your-privy-app-id
# Monad mainnet RPC (required for chain config). Override here if needed.
# The public endpoint may return HTTP 413 under heavy log queries; use a dedicated node if that happens.
VITE_MONAD_RPC_URL=https://rpc3.monad.xyz
# Optional explicit Fortytwo MCP endpoint (defaults to https://mcp.fortytwo.network/mcp)
# VITE_FORTYTWO_MCP_ENDPOINT=

# --- Legacy OpenRouter chat (kept at /test) ---
# Server-only (Vercel env or .env.local for `npm run dev`). Never use VITE_* for this.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_OPENROUTER_MODEL=moonshotai/kimi-k2.6:free
# Optional: fallback models when the primary fails (busy provider, 5xx, etc.)
# VITE_OPENROUTER_FALLBACK_MODELS=qwen/qwen3-next-80b-a3b-instruct:free,openai/gpt-oss-120b:free,nvidia/nemotron-3-super-120b-a12b:free
